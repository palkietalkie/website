{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev -p 3030",
    "build": "next build",
    "start": "next start -p 3030",
    "lint": "eslint",
    "generate:api-types": "bash scripts/generate-api-types.sh",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,css,json,md}' 'eslint.config.mjs' 'next.config.ts' 'vitest.config.ts' 'vitest.setup.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx,css,json,md}' 'eslint.config.mjs' 'next.config.ts' 'vitest.config.ts' 'vitest.setup.ts'",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.1",
    "@neondatabase/serverless": "^1.1.0",
    "@stripe/stripe-js": "^9.6.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
